// ─────────────────────────────────────────────
// prisma/schema.prisma
// EventFlow — Complete Data Model (Fixed)
// ─────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// AUTH — NextAuth.js required models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// USER (Planner)
// ─────────────────────────────────────────────

model User {
  id                   String         @id @default(cuid())
  name                 String?
  email                String?        @unique
  emailVerified        DateTime?
  image                String?        
  phone                String?
  plan                 String         @default("free")
  planExpiresAt        DateTime?
  paystackCustomerCode String?
  subscriptions        Subscription[]
  topUps               EventTopUp[]

  businessName  String?
  businessLogo  String?   

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  events         Event[]

  waAccessToken   String?
  waPhoneNumberId String?
  waWabaId        String?
  waDisplayName   String?
  waPhoneNumber   String?
  waBusinessName  String?
  waConnectedAt   DateTime?
  waMessagesSent  Int           @default(0)
}

// ─────────────────────────────────────────────
// EVENT
// ─────────────────────────────────────────────

model Event {
  id              String            @id @default(cuid())
  plannerId       String
  venueLat        Float?
  venueLng        Float?
  venueMapUrl     String?
  vendorStaff     VendorStaff[]
  vendorFeedback  VendorFeedback[]
  timeline        EventTimeline[]
  topUps          EventTopUp[]

  name          String
  slug          String       @unique
  description   String?      @db.Text
  eventType     EventType    @default(WEDDING)
  invitationCard String?     

  venueName      String?
  venueAddress   String?
  venueCapacity  Int?

  eventDate      DateTime
  startTime      String?     
  endTime        String?     

  status         EventStatus @default(DRAFT)
  rsvpDeadline   DateTime?
  isPublic       Boolean     @default(false)

  inviteModel    InviteModel @default(OPEN)
  requireOtp     Boolean     @default(false)

  totalTables    Int?
  seatsPerTable  Int?
  releaseReservedAfter Int?

  isPrivate      Boolean     @default(false)
  hostToken      String?     @unique
  hostEmail      String?
  hostName       String?

  brandColor     String?      @default("#C9A84C")
  brandLogo      String?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  planner        User        @relation(fields: [plannerId], references: [id], onDelete: Cascade)
  guestTiers     GuestTier[]
  menuItems      MenuItem[]
  guests         Guest[]
  tables         Table[]
  seatGroups     SeatGroup[]
  vendors        Vendor[]
  ushers         Usher[]
  tributes       Tribute[]
  giftRecords    GiftRecord[]
  
  // NEW: Back-relations for Vendor Payments/Complaints
  vendorPayments VendorPayment[]
  vendorComplaints VendorComplaint[]

  @@index([plannerId])
  @@index([slug])
}

enum EventType {
  WEDDING
  BIRTHDAY
  CORPORATE
  BURIAL
  ANNIVERSARY
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum InviteModel {
  OPEN
  CLOSED
}

// ─────────────────────────────────────────────
// GUEST TIERS
// ─────────────────────────────────────────────

model GuestTier {
  id          String      @id @default(cuid())
  eventId     String
  name        String      
  color       String?     
  description String?
  maxGuests   Int?        

  seatingType SeatingType @default(DYNAMIC)
  menuAccess  MenuAccess  @default(AT_EVENT)
  tablePrefix String?

  createdAt   DateTime    @default(now())

  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guests      Guest[]
  tables      Table[]

  @@index([eventId])
}

enum SeatingType {
  PRE_ASSIGNED
  DYNAMIC
}

enum MenuAccess {
  PRE_EVENT
  AT_EVENT
}

// ─────────────────────────────────────────────
// TABLE
// ─────────────────────────────────────────────

model Table {
  id               String     @id @default(cuid())
  eventId          String
  tableNumber      Int        
  label            String?    
  capacity         Int        @default(10)
  currentOccupancy Int        @default(0)

  reservedForTierId String?

  isReleased       Boolean    @default(false)
  releasedAt       DateTime?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  event            Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reservedForTier  GuestTier? @relation(fields: [reservedForTierId], references: [id])
  guests           Guest[]
  seatGroups       SeatGroup[]

  @@index([eventId])
}

// ─────────────────────────────────────────────
// SEAT GROUP
// ─────────────────────────────────────────────

model SeatGroup {
  id          String   @id @default(cuid())
  eventId     String
  code        String   @unique
  maxSize     Int      @default(10)
  tableId     String?
  createdById String?

  createdAt   DateTime @default(now())

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  table       Table?   @relation(fields: [tableId], references: [id])
  members     Guest[]

  @@index([eventId])
  @@index([code])
}

// ─────────────────────────────────────────────
// MENU ITEMS
// ─────────────────────────────────────────────

model MenuItem {
  id          String       @id @default(cuid())
  eventId     String
  category    MenuCategory
  name        String       
  description String?      
  isAvailable Boolean      @default(true)
  sortOrder   Int          @default(0)

  createdAt   DateTime     @default(now())

  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guestMeals  GuestMeal[]

  @@index([eventId])
}

enum MenuCategory {
  APPETIZER
  MAIN
  DRINK
  DESSERT
  SPECIAL
}

// ─────────────────────────────────────────────
// GUEST
// ─────────────────────────────────────────────

model Guest {
  id            String        @id @default(cuid())
  eventId       String
  tierId        String?
  seatGroupId   String?       

  firstName     String
  lastName      String
  email         String?
  phone         String?

  inviteToken      String?     @unique
  inviteTokenUsed  Boolean     @default(false)
  inviteSentAt     DateTime?
  inviteChannel    InviteChannel @default(EMAIL)

  otpCode          String?
  otpExpiresAt     DateTime?
  phoneVerified    Boolean     @default(false)

  rsvpStatus    RSVPStatus    @default(PENDING)
  rsvpAt        DateTime?

  tableId        String?       
  tableNumber    String?       
  seatNumber     String?
  seatAssignedAt DateTime?
  seatAssignedBy String?       @default("SYSTEM")

  qrCode        String        @unique @default(cuid())
  qrCodeUrl     String?       
  checkedIn     Boolean       @default(false)
  checkedInAt   DateTime?
  checkedInBy   String?       

  isFlagged     Boolean       @default(false)
  flagReason    String?       
  flaggedAt     DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  event         Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tier          GuestTier?    @relation(fields: [tierId], references: [id])
  table         Table?        @relation(fields: [tableId], references: [id])
  seatGroup     SeatGroup?    @relation(fields: [seatGroupId], references: [id])
  meals         GuestMeal[]
  tribute       Tribute?
  gifts         GiftRecord[]

  @@index([eventId])
  @@index([qrCode])
  @@index([inviteToken])
  @@index([phone])
}

enum RSVPStatus {
  PENDING
  CONFIRMED
  DECLINED
  WAITLISTED
  NO_SHOW
}

enum InviteChannel {
  EMAIL
  WHATSAPP
  SMS
  MANUAL
}

model GuestMeal {
  id         String   @id @default(cuid())
  guestId    String
  menuItemId String
  quantity   Int      @default(1)
  notes      String?  

  guest      Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@unique([guestId, menuItemId])
}

model Tribute {
  id        String   @id @default(cuid())
  eventId   String
  guestId   String   @unique
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ─────────────────────────────────────────────
// VENDOR MODELS
// ─────────────────────────────────────────────

model Vendor {
  id                     String           @id @default(cuid())
  eventId                String
  name                   String
  contactName            String?
  email                  String?
  phone                  String?
  role                   VendorRole
  notes                  String?          @db.Text
  staffCount             Int?
  arriveTime             String?
  arriveLocation         String?
  instructions           String?          @db.Text
  portalToken            String           @unique @default(cuid())
  lastAccessed           DateTime?
  canOverrideCapacity    Boolean          @default(false)
  capacityOverrideActive Boolean          @default(false)
  capacityOverrideAt     DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  totalCost              Decimal?         @db.Decimal(12,2)
  
  event                  Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  staff                  VendorStaff[]
  payments               VendorPayment[]
  complaints             VendorComplaint[]
  
  feedback               VendorFeedback?

  @@index([eventId])
  @@index([portalToken])
}

enum VendorRole {
  CATERER
  SECURITY
  MEDIA
  LIVE_BAND
  DJ
  MC
  HYPEMAN
  AFTER_PARTY
  DRINK_VENDOR
  DECORATOR
  PHOTOGRAPHER
  VIDEOGRAPHER
  OTHER
}

model VendorStaff {
  id          String    @id @default(cuid())
  vendorId    String
  eventId     String

  name        String
  phone       String?
  qrToken     String    @unique @default(cuid())
  checkedIn   Boolean   @default(false)
  checkedInAt DateTime?
  createdAt   DateTime  @default(now())

  vendor      Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  event       Event     @relation(fields: [eventId],  references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([eventId])
}

model VendorFeedback {
  id               String   @id @default(cuid())
  vendorId         String   @unique // REQUIRED for 1-to-1 relations
  eventId          String
  
  plannerRating    Int?
  plannerComment   String?  @db.Text
  plannerWouldHire Boolean?
  
  vendorRating     Int?
  vendorComment    String?  @db.Text
  vendorWouldWork  Boolean?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  event  Event  @relation(fields: [eventId],  references: [id], onDelete: Cascade)

  @@unique([vendorId, eventId])
  @@index([vendorId])
  @@index([eventId])
}

// ─────────────────────────────────────────────
// USHERS & LOGISTICS
// ─────────────────────────────────────────────

model Usher {
  id          String    @id @default(cuid())
  eventId     String
  name        String
  phone       String?
  role        UsherRole @default(FLOOR)

  accessToken String    @unique @default(cuid())
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())

  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

enum UsherRole {
  MAIN
  FLOOR
}

model GiftRecord {
  id          String     @id @default(cuid())
  eventId     String
  guestId     String?    

  giftType    GiftType
  amount      Decimal?   @db.Decimal(10, 2)
  currency    String?    @default("NGN")
  description String?    

  status      GiftStatus @default(PENDING)
  notifiedAt  DateTime?  
  processedAt DateTime?

  senderName  String?
  senderPhone String?
  senderEmail String?

  createdAt   DateTime   @default(now())

  event       Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest       Guest?     @relation(fields: [guestId], references: [id])

  @@index([eventId])
}

enum GiftType {
  CASH_TRANSFER
  CASH_PHYSICAL
  PHYSICAL_ITEM
}

enum GiftStatus {
  PENDING
  NOTIFIED
  RECEIVED
  COMPLETED
}

model EventTimeline {
  id          String   @id @default(cuid())
  eventId     String

  time        String
  title       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS & PAYMENTS
// ─────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  plan                 String
  status               SubscriptionStatus @default(ACTIVE)
  paystackSubCode      String?
  paystackCustomerCode String?
  paystackEmailToken   String?
  amount               Int
  nextBillingDate      DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([paystackSubCode])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

model EventTopUp {
  id          String      @id @default(cuid())
  userId      String
  eventId     String
  type        TopUpType
  status      TopUpStatus @default(PENDING)
  guestBonus  Int?        @default(200)
  paystackRef String?     @unique
  amount      Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eventId])
  @@index([paystackRef])
}

enum TopUpType {
  GUESTS
  WHATSAPP
  CHECKIN
}

enum TopUpStatus {
  PENDING
  ACTIVE
  FAILED
}

model PaymentLog {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  reference String?
  amount    Int?
  status    String
  raw       Json
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([reference])
}

model VendorPayment {
  id             String         @id @default(cuid())
  vendorId       String
  eventId        String
  amount         Decimal        @db.Decimal(12,2)
  method         PaymentMethod
  note           String?        @db.Text
  receiptUrl     String?        
  status         PaymentStatus  @default(PENDING)
  acknowledgedAt DateTime?
  disputedAt     DateTime?
  disputeNote    String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  event  Event  @relation(fields: [eventId],  references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([eventId])
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
}

enum PaymentStatus {
  PENDING
  ACKNOWLEDGED
  DISPUTED
}

model VendorComplaint {
  id          String            @id @default(cuid())
  vendorId    String
  eventId     String
  raisedBy    ComplaintRaisedBy
  category    String
  description String            @db.Text
  evidenceUrl String?
  status      ComplaintStatus   @default(OPEN)
  response    String?           @db.Text
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  event  Event  @relation(fields: [eventId],  references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([eventId])
}

enum ComplaintRaisedBy {
  PLANNER
  VENDOR
}

enum ComplaintStatus {
  OPEN
  IN_DISCUSSION
  RESOLVED
}